{
  "version": 2,
  "functions": {
    "index.js": {
      "includeFiles": [
        "index.html",
        "styles.css",
        "client.js",
        "config.js"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.js" }
  ]
}
